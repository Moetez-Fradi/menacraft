# ── LLM / OpenRouter (optional — heuristic fallback if unset) ───────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
LLM_ENABLED=true

# ── Scoring weights ─────────────────────────────────────────────────────────
WEIGHT_ACCOUNT_SIGNAL=0.2
WEIGHT_SUSPICIOUS_DOMAIN=0.3
WEIGHT_WRITING_STYLE=0.2

# ── Domain cache ────────────────────────────────────────────────────────────
DOMAIN_CACHE_TTL=3600
DOMAIN_CACHE_MAX_SIZE=2048

# ── Server ──────────────────────────────────────────────────────────────────
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8084
